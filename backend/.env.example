# Server Configuration
PORT=5000
NODE_ENV=development

# Security & Tokens
# IMPORTANT: Generate a strong random key in production
JWT_SECRET=she_can_foundation_secret_key_2026
JWT_EXPIRES_IN=24h

# Database Configuration
# Leave DATABASE_URL empty to use the zero-configuration local SQLite database.
# To use PostgreSQL, supply the connection URI.
# DATABASE_URL=postgres://user:password@localhost:5432/she_can_db
# DB_SSL=false

# CORS Allowed Origins (Comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Default Seeding Admin Credentials
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123
